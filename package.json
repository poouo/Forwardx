{
  "name": "forwardx",
  "version": "2.3.146",
  "description": "ForwardX 转发管理面板：多主机端口转发、加密隧道、转发组、用户权限、套餐和流量计费统一管理系统",
  "license": "AGPL-3.0-only",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx server/index.ts",
    "build": "vite build && node esbuild.config.mjs",
    "build:client": "vite build",
    "build:server": "node esbuild.config.mjs",
    "mobile:sync": "pnpm mobile:sync:android",
    "mobile:sync:android": "pnpm build:client && cap sync android",
    "mobile:open": "cap open android",
    "mobile:open:android": "cap open android",
    "mobile:apk": "pnpm mobile:sync:android && cd android && ./gradlew assembleDebug",
    "check:versions": "node scripts/check-versions.mjs",
    "start": "NODE_ENV=production node dist/index.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push"
  },
