{
  "schemaVersion": 1,
  "id": "china-region-whitelist",
  "name": "ForwardX 中国区域白名单",
  "version": "0.6.0",
  "description": "按主机实时管理中国大陆全国、省级 CIDR 和 ASN 白名单规则。",
  "detailsMarkdown": "ForwardX 中国区域白名单插件用于把中国大陆全国、省级 CIDR 和 ASN 白名单规则应用到 Agent 主机。\n\n启用后，插件程序和数据会自动同步到所有 Agent。左侧列出全部主机并支持筛选；点击主机后，可在右侧读取、新增、修改、删除和刷新该主机的实际白名单规则。每台 Agent 的配置和状态彼此独立。\n\n支持的能力：\n- 使用内置预制数据，包含全国 CN、省级 CIDR、区域索引和预制 ASN 数据。\n- 支持全国或按省份选择全局入站白名单。\n- 支持额外 ASN 白名单，例如 AS16509。\n- 支持端口优先白名单，格式如 `22=上海市,AS16509,1.2.3.4/32;10000-20000=广东省,江苏省`。\n- 支持 nftables 优先，也可指定 iptables/ipset。\n- 支持托管本机 INPUT 和 DNAT/FORWARD 入站流量，也可只托管本机入站或指定接口。\n- 自动展示在线、执行、规则挂载、持久化和失败状态。\n\n插件内置脚本参考 `GHUNLIL/china-region-whitelist` 的实现方式，并改成适合 ForwardX 通用 Agent 动态资源管理的非交互入口。",
  "author": "poouo",
  "logo": "data:image/svg+xml;base64,",
  "releaseDate": "2026-07-12",
  "updatedAt": "2026-07-14",
  "changelog": "重做白名单管理界面：左侧展示并筛选全部主机，右侧按当前主机新增、修改、删除和刷新规则。",
  "tags": ["whitelist", "china-region", "firewall", "agent"],
  "license": "Unknown",
  "homepage": "https://github.com/poouo/Forwardx",
  "repository": "https://github.com/poouo/Forwardx",
  "features": [
    {
      "title": "区域白名单",
      "description": "支持全国 CN 或按省份选择入站白名单。"
    },
    {
      "title": "端口策略",
      "description": "支持为指定端口或端口范围设置独立白名单。"
    },
    {
      "title": "Agent 下发",
      "description": "面板生成配置后由 Agent 同步脚本、数据和规则操作。"
    },
    {
      "title": "规则预演",
      "description": "应用前可以先输出将执行的 nftables/iptables 命令。"
    }
  ],
  "permissions": ["data:whitelist", "read:hosts", "agent:read", "agent:write", "ui:interactive"],
  "extensionPoints": ["data.whitelist"],
  "usageViews": [
    {
      "id": "sync-to-hosts",
      "type": "host-asset-sync",
      "storageKey": "chinaRegionWhitelistUsage",
      "title": "中国区域白名单",
      "description": "插件资源自动同步到所有 Agent；选择左侧主机后，可独立管理该主机的白名单规则。",
      "hostScope": "all",
      "enableLabel": "启用",
      "targetDirectory": "/var/lib/forwardx-agent/plugins/china-region-whitelist",
      "assetMode": "all-plugin-assets",
      "preserveAssetPaths": true,
      "disabledTitle": "插件未启用",
      "disabledDescription": "请先在插件管理中启用插件，Agent 才会接收资源和操作。",
      "assetSelector": {
        "hidden": true
      }
    }
  ],
  "resourceSchemas": [
    {
      "id": "whitelist-host-manager",
      "type": "agent-resource",
      "title": "白名单配置",
      "description": "实时读取并管理所选 Agent 上实际生效的区域白名单配置。",
      "usageViewId": "sync-to-hosts",
      "rowKey": "id",
      "listSourceId": "whitelist-list",
      "detailSourceId": "whitelist-detail",
      "emptyText": "该 Agent 尚未配置白名单，可点击右上角新增",
      "sources": [
        {
          "id": "whitelist-list",
          "actionId": "read-agent-status",
          "triggers": ["onOpen", "onHostSelected"],
          "itemsPath": "items",
          "cacheTtlMs": 5000
        },
        {
          "id": "whitelist-detail",
          "actionId": "read-whitelist-detail",
          "triggers": ["manual"],
          "selectionInputKey": "id"
        }
      ],
      "columns": [
        { "key": "name", "label": "配置", "type": "text", "path": "name" },
        { "key": "regionSummary", "label": "白名单区域", "type": "text", "path": "regionSummary" },
        { "key": "applied", "label": "规则状态", "type": "status", "path": "applied", "trueLabel": "已生效", "falseLabel": "未生效" },
        { "key": "backend", "label": "防火墙", "type": "code", "path": "backend" },
        { "key": "ruleCount", "label": "CIDR 数量", "type": "number", "path": "ruleCount" },
        { "key": "serviceActive", "label": "持久化", "type": "boolean", "path": "serviceActive", "trueLabel": "已启用", "falseLabel": "未启用" }
      ],
      "fields": [
        {
          "key": "regions",
          "label": "全局白名单区域",
          "type": "multi-select",
          "required": true,
          "defaultValue": ["CN"],
          "description": "全国与省份互斥；选择省份后仅使用所选省份 CIDR。",
          "options": [
            { "value": "CN", "label": "全国（中国大陆 CN）", "exclusive": true },
            { "value": "110000", "label": "北京市" },
            { "value": "120000", "label": "天津市" },
            { "value": "130000", "label": "河北省" },
            { "value": "140000", "label": "山西省" },
            { "value": "150000", "label": "内蒙古自治区" },
            { "value": "210000", "label": "辽宁省" },
            { "value": "220000", "label": "吉林省" },
            { "value": "230000", "label": "黑龙江省" },
            { "value": "310000", "label": "上海市" },
            { "value": "320000", "label": "江苏省" },
            { "value": "330000", "label": "浙江省" },
            { "value": "340000", "label": "安徽省" },
            { "value": "350000", "label": "福建省" },
            { "value": "360000", "label": "江西省" },
            { "value": "370000", "label": "山东省" },
            { "value": "410000", "label": "河南省" },
            { "value": "420000", "label": "湖北省" },
            { "value": "430000", "label": "湖南省" },
            { "value": "440000", "label": "广东省" },
            { "value": "450000", "label": "广西壮族自治区" },
            { "value": "460000", "label": "海南省" },
            { "value": "500000", "label": "重庆市" },
            { "value": "510000", "label": "四川省" },
            { "value": "520000", "label": "贵州省" },
            { "value": "530000", "label": "云南省" },
            { "value": "540000", "label": "西藏自治区" },
            { "value": "610000", "label": "陕西省" },
            { "value": "620000", "label": "甘肃省" },
            { "value": "630000", "label": "青海省" },
            { "value": "640000", "label": "宁夏回族自治区" },
            { "value": "650000", "label": "新疆维吾尔自治区" }
          ]
        },
        { "key": "asns", "label": "额外 ASN 白名单", "type": "textarea", "placeholder": "AS16509 AS14061", "description": "多个 ASN 可用空格、逗号或换行分隔。" },
        { "key": "portPolicies", "label": "端口优先白名单", "type": "textarea", "placeholder": "22=上海市,AS16509;10000-20000=广东省", "description": "端口策略优先于全局白名单。" },
        {
          "key": "forwardMode",
          "label": "DNAT/FORWARD 托管",
          "type": "select",
          "defaultValue": "all",
          "options": [
            { "value": "all", "label": "托管所有 DNAT 入站转发" },
            { "value": "none", "label": "只限制本机入站" },
            { "value": "selected", "label": "只托管指定接口" }
          ]
        },
        {
          "key": "forwardInterfaces",
          "label": "指定接口",
          "type": "text",
          "placeholder": "tun0 wg0",
          "visibleWhen": [{ "field": "forwardMode", "operator": "eq", "value": "selected" }]
        },
        {
          "key": "configuredBackend",
          "label": "防火墙后端",
          "type": "select",
          "defaultValue": "auto",
          "options": [
            { "value": "auto", "label": "自动选择" },
            { "value": "nft", "label": "nftables" },
            { "value": "iptables", "label": "iptables/ipset" }
          ]
        }
      ],
      "operations": {
        "create": {
          "actionId": "save-whitelist-config",
          "label": "新增白名单",
          "refreshAfter": ["whitelist-list"]
        },
        "update": {
          "actionId": "save-whitelist-config",
          "label": "修改白名单",
          "refreshAfter": ["whitelist-list", "whitelist-detail"]
        },
        "delete": {
          "actionId": "delete-whitelist-config",
          "label": "删除白名单",
          "description": "清除该 Agent 上由插件创建的白名单规则和配置。",
          "confirmRequired": true,
          "refreshAfter": ["whitelist-list"]
        }
      }
    }
  ],
  "pages": [
    {
      "id": "overview",
      "title": "插件说明",
      "contentType": "markdown",
      "assetPath": "README.md"
    }
  ],
  "actions": [
    {
      "id": "read-agent-status",
      "label": "读取主机状态",
      "type": "agent.request",
      "intent": "read",
      "description": "从已选主机读取实际白名单配置、防火墙后端、规则数量和持久化状态。",
      "agent": {
        "executor": "script",
        "interpreter": "bash",
        "target": "selected-hosts",
        "usageViewId": "sync-to-hosts",
        "entry": "forwardx-agent-run.sh",
        "arguments": ["resource-list-json"],
        "timeoutMs": 15000,
        "outputType": "json"
      }
    },
    {
      "id": "read-whitelist-detail",
      "label": "读取白名单详情",
      "type": "agent.request",
      "intent": "read",
      "agent": {
        "executor": "script",
        "interpreter": "bash",
        "target": "selected-hosts",
        "usageViewId": "sync-to-hosts",
        "entry": "forwardx-agent-run.sh",
        "arguments": ["status-json"],
        "timeoutMs": 15000,
        "outputType": "json"
      },
      "resultSchema": {
        "type": "table",
        "itemsPath": "items",
        "fields": [
          { "key": "name", "label": "配置" },
          { "key": "applied", "label": "规则状态", "type": "statusBadge", "trueLabel": "已生效", "falseLabel": "未生效" },
          { "key": "regionSummary", "label": "白名单区域" },
          { "key": "backend", "label": "防火墙", "type": "code" },
          { "key": "ruleCount", "label": "CIDR 数量", "type": "number" }
        ]
      }
    },
    {
      "id": "save-whitelist-config",
      "label": "保存并应用白名单",
      "type": "agent.request",
      "intent": "write",
      "agent": {
        "executor": "script",
        "interpreter": "bash",
        "target": "selected-hosts",
        "usageViewId": "sync-to-hosts",
        "entry": "forwardx-agent-run.sh",
        "arguments": ["resource-save", "{{input.payload}}"],
        "timeoutMs": 30000,
        "outputType": "json"
      },
      "resultSchema": {
        "type": "keyValue",
        "fields": [
          { "key": "applied", "label": "规则状态", "type": "statusBadge", "trueLabel": "已生效", "falseLabel": "未生效" },
          { "key": "regionSummary", "label": "白名单区域" },
          { "key": "backend", "label": "防火墙", "type": "code" },
          { "key": "ruleCount", "label": "CIDR 数量", "type": "number" },
          { "key": "configPath", "label": "配置路径", "type": "code", "copyable": true }
        ]
      }
    },
    {
      "id": "delete-whitelist-config",
      "label": "清理白名单规则",
      "type": "agent.request",
      "intent": "write",
      "agent": {
        "executor": "script",
        "interpreter": "bash",
        "target": "selected-hosts",
        "usageViewId": "sync-to-hosts",
        "entry": "forwardx-agent-run.sh",
        "arguments": ["resource-delete"],
        "timeoutMs": 30000,
        "outputType": "json"
      }
    },
    {
      "id": "refresh-whitelist-source",
      "label": "刷新插件数据",
      "type": "data.asset.refresh",
      "description": "从插件源重新同步 data 目录中的数据文件。",
      "confirmRequired": true
    }
  ],
  "assets": [
    {
      "path": "README.md",
      "label": "插件说明",
      "contentType": "text/markdown;charset=utf-8"
    },
    {
